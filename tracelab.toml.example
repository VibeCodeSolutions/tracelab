# Tracelab Hub configuration
# Copy to tracelab.toml and adjust. The .example file is tracked,
# tracelab.toml is gitignored.

[server]
port = 8765
bind = "0.0.0.0"     # accessible from LAN/VMs; use "127.0.0.1" to lock down
read_timeout  = "15s"
write_timeout = "15s"

[storage]
datastore_path = "/run/media/kaik/AE62672C6266F88B/tracelab"
# On Windows: "D:\\tracelab" (or whichever drive letter mounts the NTFS partition)

[auth]
# Shared bearer secret for the API. Generate a fresh one per environment, e.g.:
#   openssl rand -hex 32
# The hub refuses to start while this is empty or the literal "CHANGEME".
token = "CHANGEME"

# Optional ADB-logcat bridge. When enabled, the hub spawns a background
# goroutine that runs `adb logcat -v threadtime` and ingests each line as
# an event with source="adb". The bridge reconnects with exponential
# backoff on subprocess exit; each reconnect opens a NEW session so
# disconnect gaps stay visible in the forensic trail.
#
# Phase 2a / S5 (2026-05-14): bridge lifecycle is now managed per-serial so
# the same hub can drive multiple devices (config-driven auto-start + the
# HTTP /adb/* control surface use one shared manager). As a consequence,
# `device_serial` is REQUIRED when `enabled = true` — there is no implicit
# "first attached device" anymore. Discover serials with the CLI:
#   `tracelab adb devices`, then pin one here.
[adb]
enabled       = false       # set to true once `adb devices` shows your target
device_serial = ""          # REQUIRED when enabled=true (no implicit "first device")
tag_filter    = ""          # optional single-tag filter, e.g. "MyApp"

# Optional Phase-2d agent-observability sources. Each source is independent;
# enable any subset. All sources write into the same agent_* tables and are
# dedup'd at the schema layer (UNIQUE-tuple on agent_tokens preserves
# per-source forensics — see ADR-013).
#
# [agents.transcript] — Phase 2d S2 transcript-tail bridge.
# When enabled, the hub polls every *.jsonl file under projects_root for new
# lines (plus the per-session subagents/agent-*.jsonl files), parses each
# Claude-Code transcript record, and persists spawn / token / verdict events
# with source="transcript". Coexists with the SDK-hook source from S1 — the
# UNIQUE tuple on agent_tokens(spawn_id, ts, source) keeps both rows for
# per-source disagreement debugging.
#
# The field mapping was empirically verified against real transcripts; see
# docs/ARCH.md §Phase 2d §Transcript-Tail for the schema-to-JSONL mapping.
#
# [agents.transcript]
# enabled          = false               # set true to start tailing
# projects_root    = "~/.claude/projects" # default; ~ is expanded at start-up
# poll_interval_ms = 1000                # default 1 s tail cycle
